# Master .gitignore for PG Booking Website

# Dependency directories
node_modules/
Frontend/node_modules/
Backend/node_modules/

# Environment files (Sensitive Info)
.env
Backend/.env
Frontend/.env

# Generated PDF Bills (Dynamic Data)
bills/
Backend/bills/

# Logs and Debug files
*.log
Backend/debug.log
Backend/logs/
.DS_Store

# Build/Production outputs
dist/
Frontend/dist/
build/
.cache
.parcel-cache

# IDE / Editor folders
.vscode/
.idea/
*.swp
*.swo
